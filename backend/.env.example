# ============================================
# 智能医疗管家平台 - 环境变量模板
# 复制为 .env 并填写实际值: cp .env.example .env
# ============================================

# --- 应用 ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# --- 安全（生产环境必填）---
SECRET_KEY=change-me-to-a-long-random-string
ENABLE_AUTH_MIDDLEWARE=false
METRICS_ACCESS_TOKEN=
STARTUP_FAIL_FAST=true
RATE_LIMIT_FAIL_CLOSED=false

# --- 数据库 ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medical_consultation

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=medical123

# --- Milvus ---
MILVUS_HOST=localhost
MILVUS_PORT=19530

# --- LLM（至少配置一种）---
LLM_PROVIDER=qwen
QWEN_API_KEY=your-qwen-api-key-here
QWEN_MODEL=qwen-turbo

# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_MODEL=deepseek-chat

# --- 对象存储 ---
OBJECT_STORAGE_TYPE=minio
OBJECT_STORAGE_ENDPOINT=localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=medical-documents
OBJECT_STORAGE_USE_SSL=false

# --- Langfuse（可选）---
ENABLE_LANGFUSE=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- CORS（生产环境改为实际域名）---
# CORS_ORIGINS=["https://yourdomain.com"]
